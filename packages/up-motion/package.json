{
	"name": "up-motion",
	"description": "Advanced animation toolkit for Vue with motion-v",
	"version": "1.0.0-alpha.3",
	"type": "module",
	"keywords": [
		"vue",
		"animation",
		"motion",
		"performance"
	],
	"main": "./dist/cjs/up-motion.cjs",
	"module": "./dist/es/up-motion.es.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/es/up-motion.es.js",
			"require": "./dist/cjs/up-motion.cjs"
		},
		"./composables": "./dist/composables/index.es.js",
		"./components": "./dist/components/index.es.js",
		"./components/*": "./dist/components/*/index.es.js",
		"./animations/*": "./dist/animations/*.es.js"
	},
	"files": [
		"dist/es/",
		"dist/cjs/",
		"dist/index.d.ts",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"build": "run-s build:types build:lib",
		"build:lib": "rimraf dist && vite build",
		"build:types": "vue-tsc --project tsconfig.build.json",
		"size": "size-limit --debug",
		"analyze": "size-limit --why",
		"type-check": "vue-tsc --noEmit",
		"test": "vitest",
		"test:unit": "vitest run --project=Unit",
		"test:dom": "vitest run --project=Component",
		"coverage": "vitest run --coverage",
		"preview:coverage": "vite preview --outDir ./coverage",
		"test:browser": "vitest --config=vitest.browser.config.ts",
		"docs:dev": "cd docs && npm run dev"
	},
	"dependencies": {
		"motion-v": "^1.10.2"
	},
	"devDependencies": {
		"@size-limit/esbuild": "^12.0.0",
		"@size-limit/esbuild-why": "^12.0.0",
		"@size-limit/file": "^12.0.0",
		"@size-limit/preset-small-lib": "^12.0.0",
		"@size-limit/time": "^12.0.0",
		"@types/node": "^24.10.1",
		"@vitejs/plugin-vue": "^6.0.3",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.8.1",
		"jsdom": "^28.0.0",
		"npm-run-all": "^4.1.5",
		"rimraf": "^6.1.2",
		"rollup-plugin-visualizer": "^6.0.5",
		"size-limit": "^12.0.0",
		"terser": "^5.46.0",
		"typescript": "~5.9.3",
		"vite": "^7.2.4",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.0.18",
		"vitest-browser-vue": "^2.0.2",
		"vue-tsc": "^3.1.4"
	},
	"peerDependencies": {
		"vue": "^3.3.0"
	}
}
