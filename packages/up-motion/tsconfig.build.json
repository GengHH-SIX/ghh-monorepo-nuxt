{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"declarationMap": false,
		"emitDeclarationOnly": true,
		"allowImportingTsExtensions": true,
		"outDir": "./dist/es",
		"rootDir": "./src",
		"noEmit": true,
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/**/__test__/*"]
}
